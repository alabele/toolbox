#!/usr/bin/env bash
set -euo pipefail

# claude-pr-loop — Automated PR review-fix loop using Claude Code CLI
#
# Usage:
#   claude-pr-loop https://github.com/owner/repo/pull/123
#   claude-pr-loop owner/repo#123
#   claude-pr-loop --label needs-review --repo owner/repo
#   claude-pr-loop --no-fix https://github.com/owner/repo/pull/123

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
MAX_ITERATIONS=5
MAX_BUDGET="2.00"
MODEL="sonnet"
EFFORT="high"
LOG_DIR="${HOME}/.claude-pr-loop/logs"
WORKTREE_BASE="${HOME}/.claude-pr-loop/worktrees"
NO_FIX=false
DRY_RUN=false
BATCH_LABEL=""
BATCH_REPO=""
PR_INPUT=""

# Resolved per-PR (set by parse_pr_url)
OWNER_REPO=""
PR_NUMBER=""

# Token/cost tracking (accumulated across iterations)
TOTAL_INPUT_TOKENS=0
TOTAL_OUTPUT_TOKENS=0
TOTAL_CACHE_READ_TOKENS=0
TOTAL_CACHE_CREATION_TOKENS=0
TOTAL_COST_USD="0"

# Per-iteration usage records, populated by track_usage and serialized at end of PR.
# Each entry is a JSON object: {step, iteration, input_tokens, output_tokens, ...}
ITERATION_USAGE=()
DIFF_FILTER_SKIPPED_FILES=0
DIFF_FILTER_SKIPPED_BYTES=0
DIFF_RAW_BYTES=0
DIFF_FILTERED_BYTES=0

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
log() {
  local log_file="$1" message="$2"
  local ts
  ts=$(date '+%Y-%m-%d %H:%M:%S')
  echo "[${ts}] ${message}" | tee -a "$log_file"
}

notify() {
  local title="$1" message="$2"
  if command -v terminal-notifier >/dev/null 2>&1; then
    terminal-notifier -title "$title" -message "$message" -sound Glass 2>/dev/null || true
  else
    osascript -e "display notification \"${message}\" with title \"${title}\" sound name \"Glass\"" 2>/dev/null || true
  fi
}

# Extract token usage from claude JSON output and accumulate totals.
# Logs per-call stats, updates running totals, and appends a JSON record to
# ITERATION_USAGE for the per-PR metrics file. Pass iteration as 4th arg.
track_usage() {
  local claude_output="$1" step_label="$2" log_file="$3" iteration="${4:-0}"

  local input_tokens output_tokens cache_read cache_creation cost_usd
  # Top-level .usage is sometimes empty on success envelopes — fall back to
  # modelUsage which always has the per-model breakdown.
  input_tokens=$(echo "$claude_output" | jq -r '.usage.input_tokens // ([.modelUsage // {} | to_entries[].value.inputTokens] | add) // 0' 2>/dev/null)
  output_tokens=$(echo "$claude_output" | jq -r '.usage.output_tokens // ([.modelUsage // {} | to_entries[].value.outputTokens] | add) // 0' 2>/dev/null)
  cache_read=$(echo "$claude_output" | jq -r '.usage.cache_read_input_tokens // ([.modelUsage // {} | to_entries[].value.cacheReadInputTokens] | add) // 0' 2>/dev/null)
  cache_creation=$(echo "$claude_output" | jq -r '.usage.cache_creation_input_tokens // ([.modelUsage // {} | to_entries[].value.cacheCreationInputTokens] | add) // 0' 2>/dev/null)
  cost_usd=$(echo "$claude_output" | jq -r '.total_cost_usd // 0' 2>/dev/null)

  # Accumulate
  TOTAL_INPUT_TOKENS=$((TOTAL_INPUT_TOKENS + input_tokens))
  TOTAL_OUTPUT_TOKENS=$((TOTAL_OUTPUT_TOKENS + output_tokens))
  TOTAL_CACHE_READ_TOKENS=$((TOTAL_CACHE_READ_TOKENS + cache_read))
  TOTAL_CACHE_CREATION_TOKENS=$((TOTAL_CACHE_CREATION_TOKENS + cache_creation))
  TOTAL_COST_USD=$(echo "$TOTAL_COST_USD + $cost_usd" | bc -l)

  local formatted_cost
  formatted_cost=$(printf '%.4f' "$cost_usd")
  log "$log_file" "  ${step_label} usage: ${input_tokens} in / ${output_tokens} out / ${cache_read} cache-read / ${cache_creation} cache-write / \$${formatted_cost}"

  # Record this call into the per-iteration usage array.
  local entry
  entry=$(jq -n \
    --arg step "$step_label" \
    --argjson iter "$iteration" \
    --argjson in_tokens "$input_tokens" \
    --argjson out_tokens "$output_tokens" \
    --argjson cr "$cache_read" \
    --argjson cw "$cache_creation" \
    --argjson cost "$cost_usd" \
    '{step:$step, iteration:$iter, input_tokens:$in_tokens, output_tokens:$out_tokens, cache_read:$cr, cache_creation:$cw, cost_usd:$cost}' 2>/dev/null) || entry=""
  if [[ -n "$entry" ]]; then
    ITERATION_USAGE+=("$entry")
  fi
}

# Filter the raw `gh pr diff` output: drop file sections matching skip patterns
# (lockfiles, snapshots, minified bundles). Reads from stdin, writes filtered
# diff to stdout, and updates DIFF_FILTER_SKIPPED_* globals as a side effect.
# Patterns are conservative — chosen to almost never be load-bearing for review.
filter_diff() {
  local raw="$1" log_file="$2"
  DIFF_RAW_BYTES=${#raw}

  # mktemp avoids `$$` collisions in batch mode, where multiple single_pr_loop
  # invocations are backgrounded subshells sharing the parent's PID.
  local stderr_file
  stderr_file=$(mktemp "${TMPDIR:-/tmp}/claude-pr-loop-filter.XXXXXX")

  # awk strips file sections matching skip patterns. A "section" is the lines
  # from one `diff --git` header up to (but not including) the next.
  local result
  result=$(printf '%s' "$raw" | awk '
    BEGIN { skip = 0; skipped_count = 0; skipped_bytes = 0; skip_list = "" }
    /^diff --git / {
      # Standard diff header: `diff --git a/<path> b/<path>`. Use field 4.
      path = $4
      sub(/^b\//, "", path)
      if (path ~ /(^|\/)(package-lock\.json|yarn\.lock|pnpm-lock\.yaml|npm-shrinkwrap\.json|Cargo\.lock|Gemfile\.lock|poetry\.lock|composer\.lock|Pipfile\.lock)$/ ||
          path ~ /(^|\/)go\.sum$/ ||
          path ~ /\.snap$/ ||
          path ~ /\.min\.(js|css|map)$/) {
        skip = 1
        skipped_count++
        skip_list = skip_list (skip_list ? ", " : "") path
      } else {
        skip = 0
      }
    }
    {
      if (skip) {
        skipped_bytes += length($0) + 1
      } else {
        print
      }
    }
    END {
      print "FILTER_COUNT=" skipped_count > "/dev/stderr"
      print "FILTER_BYTES=" skipped_bytes > "/dev/stderr"
      print "FILTER_LIST=" (skip_list ? skip_list : "(none)") > "/dev/stderr"
    }
  ' 2>"$stderr_file")

  if [[ -f "$stderr_file" ]]; then
    local count bytes list
    count=$(grep '^FILTER_COUNT=' "$stderr_file" | cut -d= -f2-)
    bytes=$(grep '^FILTER_BYTES=' "$stderr_file" | cut -d= -f2-)
    list=$(grep '^FILTER_LIST=' "$stderr_file" | cut -d= -f2-)
    rm -f "$stderr_file"
    DIFF_FILTER_SKIPPED_FILES="${count:-0}"
    DIFF_FILTER_SKIPPED_BYTES="${bytes:-0}"
    log "$log_file" "Diff filter: skipped ${DIFF_FILTER_SKIPPED_FILES} file(s), ${DIFF_FILTER_SKIPPED_BYTES} bytes (${list:-none})"
  fi

  DIFF_FILTERED_BYTES=${#result}
  printf '%s' "$result"
}

# Append a JSONL summary record for this PR run. Used to answer questions like
# "how often do we multi-iterate?" and "what would caching have saved?" later
# via `jq` over ~/.claude-pr-loop/metrics.jsonl.
write_metrics() {
  local pr="$1" verdict="$2" iter_count="$3" log_file="$4"
  local metrics_file="${HOME}/.claude-pr-loop/metrics.jsonl"
  mkdir -p "$(dirname "$metrics_file")"

  local per_iter="[]"
  if [[ ${#ITERATION_USAGE[@]} -gt 0 ]]; then
    per_iter=$(printf '%s\n' "${ITERATION_USAGE[@]}" | jq -s '.' 2>/dev/null || echo "[]")
  fi

  # Normalize bc output (which can produce ".123" without leading zero) into
  # a string jq can parse as a number.
  local cost_str
  cost_str=$(printf '%.6f' "$TOTAL_COST_USD" 2>/dev/null || echo "0")

  jq -n \
    --arg ts "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
    --arg pr "$pr" \
    --arg verdict "$verdict" \
    --arg model "$MODEL" \
    --argjson iters "$iter_count" \
    --argjson cost "$cost_str" \
    --argjson in_tokens "$TOTAL_INPUT_TOKENS" \
    --argjson out_tokens "$TOTAL_OUTPUT_TOKENS" \
    --argjson cache_read "$TOTAL_CACHE_READ_TOKENS" \
    --argjson cache_creation "$TOTAL_CACHE_CREATION_TOKENS" \
    --argjson diff_raw "$DIFF_RAW_BYTES" \
    --argjson diff_filtered "$DIFF_FILTERED_BYTES" \
    --argjson diff_skipped_files "$DIFF_FILTER_SKIPPED_FILES" \
    --argjson diff_skipped_bytes "$DIFF_FILTER_SKIPPED_BYTES" \
    --argjson per_iter "$per_iter" \
    '{
      ts:$ts, pr:$pr, model:$model, verdict:$verdict, iterations:$iters,
      total_cost_usd:$cost,
      total_input_tokens:$in_tokens, total_output_tokens:$out_tokens,
      total_cache_read:$cache_read, total_cache_creation:$cache_creation,
      diff_raw_bytes:$diff_raw, diff_filtered_bytes:$diff_filtered,
      diff_skipped_files:$diff_skipped_files, diff_skipped_bytes:$diff_skipped_bytes,
      per_iteration:$per_iter
    }' >> "$metrics_file" 2>>"$log_file" || log "$log_file" "WARN: failed to write metrics record"
}

# Log the accumulated usage summary
log_usage_summary() {
  local log_file="$1" iteration_count="$2"
  local formatted_total
  formatted_total=$(printf '%.4f' "$TOTAL_COST_USD")

  log "$log_file" "=== Usage Summary ==="
  log "$log_file" "  Iterations:     ${iteration_count}"
  log "$log_file" "  Input tokens:   ${TOTAL_INPUT_TOKENS}"
  log "$log_file" "  Output tokens:  ${TOTAL_OUTPUT_TOKENS}"
  log "$log_file" "  Cache read:     ${TOTAL_CACHE_READ_TOKENS}"
  log "$log_file" "  Cache write:    ${TOTAL_CACHE_CREATION_TOKENS}"
  log "$log_file" "  Total cost:     \$${formatted_total}"
}

usage() {
  cat <<'EOF'
Usage: claude-pr-loop [OPTIONS] [PR_URL]

Automates the review-fix-push cycle for GitHub PRs using Claude Code.

Single PR:
  claude-pr-loop https://github.com/owner/repo/pull/123
  claude-pr-loop owner/repo#123

Batch (parallel):
  claude-pr-loop --label needs-review --repo owner/repo

Options:
  --max-iterations N     Max review-fix cycles (default: 5)
  --max-budget-usd N     Per-iteration spend cap in USD (default: 2.00)
  --model MODEL          Claude model: sonnet, opus, haiku (default: sonnet)
  --effort LEVEL         low | medium | high | max (default: high)
  --log-dir PATH         Log directory (default: ~/.claude-pr-loop/logs)
  --no-fix               Review-only mode — post review but do not fix
  --label LABEL          Batch: filter PRs by this label (requires --repo)
  --repo OWNER/REPO      Batch: target repository
  --dry-run              Print what would happen without executing
  -h, --help             Show this help
EOF
  exit 0
}

# ---------------------------------------------------------------------------
# Arg parsing
# ---------------------------------------------------------------------------
parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --max-iterations)  MAX_ITERATIONS="$2"; shift 2 ;;
      --max-budget-usd)  MAX_BUDGET="$2"; shift 2 ;;
      --model)           MODEL="$2"; shift 2 ;;
      --effort)          EFFORT="$2"; shift 2 ;;
      --log-dir)         LOG_DIR="$2"; shift 2 ;;
      --no-fix)          NO_FIX=true; shift ;;
      --dry-run)         DRY_RUN=true; shift ;;
      --label)           BATCH_LABEL="$2"; shift 2 ;;
      --repo)            BATCH_REPO="$2"; shift 2 ;;
      -h|--help)         usage ;;
      -*)                echo "Unknown option: $1" >&2; exit 1 ;;
      *)                 PR_INPUT="$1"; shift ;;
    esac
  done

  # Validate: need either a PR or batch args
  if [[ -z "$PR_INPUT" && -z "$BATCH_LABEL" ]]; then
    echo "Error: provide a PR URL or --label + --repo for batch mode" >&2
    exit 1
  fi
  if [[ -n "$BATCH_LABEL" && -z "$BATCH_REPO" ]]; then
    echo "Error: --label requires --repo" >&2
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# PR URL parsing
# ---------------------------------------------------------------------------
parse_pr_url() {
  local input="$1"

  # Full URL: https://github.com/owner/repo/pull/123
  if [[ "$input" =~ github\.com/([^/]+/[^/]+)/pull/([0-9]+) ]]; then
    OWNER_REPO="${BASH_REMATCH[1]}"
    PR_NUMBER="${BASH_REMATCH[2]}"
    return
  fi

  # Shorthand: owner/repo#123
  if [[ "$input" =~ ^([^/]+/[^#]+)#([0-9]+)$ ]]; then
    OWNER_REPO="${BASH_REMATCH[1]}"
    PR_NUMBER="${BASH_REMATCH[2]}"
    return
  fi

  echo "Error: cannot parse PR from '${input}'" >&2
  echo "Expected: https://github.com/owner/repo/pull/123 or owner/repo#123" >&2
  exit 1
}

# ---------------------------------------------------------------------------
# Worktree management
# ---------------------------------------------------------------------------
setup_worktree() {
  local owner_repo="$1" pr_number="$2"
  local repo_dir="${WORKTREE_BASE}/${owner_repo//\//_}"
  local bare_repo="${repo_dir}/bare.git"
  local worktree_dir="${repo_dir}/pr-${pr_number}"

  mkdir -p "$repo_dir"

  # Clone bare repo if not present (all git output to stderr to keep stdout clean)
  if [[ ! -d "$bare_repo" ]]; then
    echo "Cloning bare repo for ${owner_repo}..." >&2
    git clone --bare "https://github.com/${owner_repo}.git" "$bare_repo" >&2
  else
    # Fetch latest
    git -C "$bare_repo" fetch origin >&2 2>&1 || true
  fi

  # Fetch the PR head ref
  git -C "$bare_repo" fetch origin "pull/${pr_number}/head:pr-${pr_number}" --force >&2 2>&1

  # Remove stale worktree if it exists
  if [[ -d "$worktree_dir" ]]; then
    git -C "$bare_repo" worktree remove --force "$worktree_dir" >&2 2>&1 || true
    rm -rf "$worktree_dir" 2>/dev/null || true
  fi

  # Create fresh worktree
  git -C "$bare_repo" worktree add "$worktree_dir" "pr-${pr_number}" >&2 2>&1

  # Fetch all branch/remote metadata in one gh call, then validate before use.
  # An empty head_ref slipping through here writes a `[branch ""]` section to
  # the bare repo's config that poisons every later git invocation against it
  # — git treats `branch..remote` as a fatal parse error and refuses to read
  # the config at all, blocking fetch/worktree/checkout for the whole repo.
  local pr_meta head_ref fork_owner fork_repo
  pr_meta=$(gh pr view "$pr_number" --repo "$owner_repo" \
    --json headRefName,headRepositoryOwner,headRepository) || {
    echo "ERROR: gh pr view failed for ${owner_repo}#${pr_number}" >&2
    exit 1
  }
  head_ref=$(echo "$pr_meta" | jq -r '.headRefName // empty')
  fork_owner=$(echo "$pr_meta" | jq -r '.headRepositoryOwner.login // empty')
  fork_repo=$(echo "$pr_meta" | jq -r '.headRepository.name // empty')
  if [[ -z "$head_ref" || -z "$fork_owner" || -z "$fork_repo" ]]; then
    echo "ERROR: gh pr view returned incomplete metadata for ${owner_repo}#${pr_number}: head_ref='${head_ref}' fork_owner='${fork_owner}' fork_repo='${fork_repo}'" >&2
    exit 1
  fi

  cd "$worktree_dir"
  git checkout -B "$head_ref" "pr-${pr_number}" >&2 2>&1

  # Configure remote for push (use gh-authenticated URL)
  git remote set-url origin "https://github.com/${fork_owner}/${fork_repo}.git" 1>&2
  # Set upstream tracking by writing branch config directly. The bare repo's
  # fetch refspec is +refs/heads/*:refs/heads/* (mirror), so origin/<head_ref>
  # never exists locally and --set-upstream-to would fire setUpstreamFailure.
  git config "branch.${head_ref}.remote" origin 1>&2
  git config "branch.${head_ref}.merge" "refs/heads/${head_ref}" 1>&2

  echo "$worktree_dir"
}

cleanup_worktree() {
  local worktree_dir="$1"
  if [[ -z "$worktree_dir" || ! -d "$worktree_dir" ]]; then
    return
  fi
  local bare_repo
  bare_repo="$(dirname "$worktree_dir")/bare.git"
  if [[ -d "$bare_repo" ]]; then
    git -C "$bare_repo" worktree remove --force "$worktree_dir" 2>/dev/null || true
  fi
  rm -rf "$worktree_dir" 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# Review step — read-only Claude call
# ---------------------------------------------------------------------------
run_review() {
  local owner_repo="$1" pr_number="$2" iteration="$3" log_file="$4" worktree_dir="$5"

  # --from-pr is a session-resume flag, not a context loader, so we inline the
  # PR description, comments, reviews, and diff here. Without this the model
  # has nothing to evaluate and replies "No PR diff or git context found".
  local pr_metadata pr_diff_raw pr_diff
  pr_metadata=$(gh pr view "$pr_number" --repo "$owner_repo" \
    --json title,body,author,headRefName,baseRefName,reviews,comments \
    2>>"$log_file") || pr_metadata="{}"
  pr_diff_raw=$(gh pr diff "$pr_number" --repo "$owner_repo" 2>>"$log_file") || pr_diff_raw=""
  # Strip lockfiles/snapshots/minified bundles before inlining — these often
  # dominate large PRs (1MB+ diffs) and rarely warrant token-by-token review.
  pr_diff=$(filter_diff "$pr_diff_raw" "$log_file")

  local review_prompt
  review_prompt="You are reviewing this PR for code quality, correctness, and completeness.

Analyze the PR diff, description, and any existing review comments carefully.
This is review iteration ${iteration}. If prior fixes were attempted, focus on remaining issues.

PR metadata (JSON):
${pr_metadata}

PR diff:
\`\`\`diff
${pr_diff}
\`\`\`

You MUST output ONLY a JSON object (no markdown fences, no preamble) with this structure:
{
  \"verdict\": \"approve\" or \"changes_requested\",
  \"summary\": \"One paragraph overall assessment\",
  \"findings\": [
    {
      \"severity\": \"critical\" | \"warning\" | \"suggestion\",
      \"file\": \"path/to/file\",
      \"line\": 42,
      \"message\": \"Description of the issue\",
      \"suggestion\": \"How to fix it\"
    }
  ],
  \"review_comment\": \"Full formatted markdown review comment for GitHub\"
}

Rules:
- Only use \"changes_requested\" if there are critical or warning findings
- Suggestions alone should NOT block approval
- Be specific about file paths and line numbers
- The review_comment should be well-formatted GitHub markdown with findings organized by severity
- If the code is solid with only minor suggestions, approve it"

  local pr_url="https://github.com/${owner_repo}/pull/${pr_number}"

  cd "$worktree_dir"
  # Pipe the prompt via stdin — inlined PR diffs can exceed ARG_MAX
  # (~256KB on macOS), causing exec to fail with "Argument list too long".
  # Capture rc via `|| rc=$?` so we see Claude's real exit code; `if ! cmd; ...; $?`
  # would log 0 because `!` already inverted the status.
  local output rc=0
  output=$(printf '%s' "$review_prompt" | claude -p \
    --from-pr "$pr_url" \
    --output-format json \
    --permission-mode "default" \
    --model "$MODEL" \
    --max-budget-usd "$MAX_BUDGET" 2>>"$log_file") || rc=$?
  if [[ $rc -ne 0 ]]; then
    # Claude writes a JSON error envelope to stdout before exiting non-zero.
    # Inspect it to give a specific message for known failure subtypes.
    local subtype="" cost=""
    if [[ -n "$output" ]]; then
      subtype=$(echo "$output" | jq -r '.subtype // empty' 2>/dev/null)
      cost=$(echo "$output" | jq -r '.total_cost_usd // empty' 2>/dev/null)
    fi
    if [[ "$subtype" == "error_max_budget_usd" ]]; then
      local suggested
      suggested=$(awk -v c="${cost:-$MAX_BUDGET}" 'BEGIN{ printf "%.2f", (c*2.5) }')
      log "$log_file" "ERROR: claude review hit --max-budget-usd cap of \$${MAX_BUDGET} (spent \$${cost}). Rerun with --max-budget-usd ${suggested} or larger."
    else
      log "$log_file" "ERROR: claude review invocation failed (exit ${rc}, subtype='${subtype:-none}'). See log for stderr."
    fi
    if [[ -n "$output" ]]; then
      echo "--- Claude stdout on failure ---" >> "$log_file"
      printf '%s\n' "$output" >> "$log_file"
      echo "--- End stdout ---" >> "$log_file"
    fi
    return 1
  fi
  printf '%s' "$output"
}

# ---------------------------------------------------------------------------
# Parse Claude's JSON-envelope output to extract the review
# ---------------------------------------------------------------------------
parse_review() {
  local claude_output="$1"

  # claude --output-format json wraps response in {"result": "..."}
  local result_text
  result_text=$(echo "$claude_output" | jq -r '.result // empty' 2>/dev/null)

  if [[ -z "$result_text" ]]; then
    # Maybe it's raw text (no envelope)
    result_text="$claude_output"
  fi

  # Strip markdown code fences if present
  result_text=$(echo "$result_text" | sed '/^```json$/d; /^```$/d; /^```$/d')

  # Try to parse as JSON directly
  if echo "$result_text" | jq -e '.verdict' >/dev/null 2>&1; then
    echo "$result_text"
    return
  fi

  # Try to extract a JSON object from the text
  local extracted
  extracted=$(echo "$result_text" | python3 -c "
import sys, json, re
text = sys.stdin.read()
match = re.search(r'\{[\s\S]*\}', text)
if match:
    try:
        obj = json.loads(match.group())
        print(json.dumps(obj))
    except json.JSONDecodeError:
        pass
" 2>/dev/null)

  if [[ -n "$extracted" ]] && echo "$extracted" | jq -e '.verdict' >/dev/null 2>&1; then
    echo "$extracted"
    return
  fi

  # Failed to parse
  echo ""
}

# ---------------------------------------------------------------------------
# Post review to GitHub
# ---------------------------------------------------------------------------
post_review() {
  local pr_number="$1" owner_repo="$2" review_json="$3" log_file="$4"

  local verdict comment
  verdict=$(echo "$review_json" | jq -r '.verdict')
  comment=$(echo "$review_json" | jq -r '.review_comment')

  # Write to temp file to avoid shell escaping issues
  local body_file
  body_file=$(mktemp "${TMPDIR:-/tmp}/claude-pr-loop-review.XXXXXX.md")

  printf '%s\n\n---\n*Automated review by claude-pr-loop (iteration %s)*' "$comment" "$iteration" > "$body_file"

  local review_output
  if [[ "$verdict" == "approve" ]]; then
    log "$log_file" "Posting APPROVE review"
    if review_output=$(gh pr review "$pr_number" --repo "$owner_repo" --approve --body-file "$body_file" 2>&1); then
      log "$log_file" "Review submitted successfully"
    elif echo "$review_output" | grep -qiE "your own pull request|can not approve|cannot approve|author of this pull request"; then
      log "$log_file" "Cannot approve own PR — posting as comment"
      gh pr comment "$pr_number" --repo "$owner_repo" --body-file "$body_file" 2>>"$log_file"
    else
      log "$log_file" "Review submission failed: ${review_output}"
    fi
  else
    log "$log_file" "Posting REQUEST_CHANGES review"
    if review_output=$(gh pr review "$pr_number" --repo "$owner_repo" --request-changes --body-file "$body_file" 2>&1); then
      log "$log_file" "Review submitted successfully"
    elif echo "$review_output" | grep -qiE "your own pull request|can not approve|cannot approve|author of this pull request"; then
      log "$log_file" "Cannot submit formal review on own PR — posting as comment"
      gh pr comment "$pr_number" --repo "$owner_repo" --body-file "$body_file" 2>>"$log_file"
    else
      log "$log_file" "Review submission failed: ${review_output}"
    fi
  fi

  rm -f "$body_file"
}

# ---------------------------------------------------------------------------
# Fix step — Claude with write permissions in worktree
# ---------------------------------------------------------------------------
run_fix() {
  local worktree_dir="$1" review_json="$2" log_file="$3" iteration="${4:-0}"

  local findings_text
  findings_text=$(echo "$review_json" | jq -r '
    [.findings[] | select(.severity != "suggestion")] |
    map("- [\(.severity)] \(.file):\(.line // "?") — \(.message)\n  Fix: \(.suggestion // "see above")") |
    join("\n\n")
  ')

  local fix_prompt="You are fixing PR review feedback in this repository.

Here are the findings that need to be addressed:

${findings_text}

Instructions:
1. Read each file mentioned in the findings
2. Fix every critical and warning issue
3. Run any relevant linters or tests if config files exist (package.json scripts, Makefile, etc.)
4. Stage your changes with git add (specific files only, not -A)
5. Commit with a message like: \"fix: address PR review feedback\"
6. Push to the remote branch with: git push

Address ALL findings. Do not skip any."

  cd "$worktree_dir"

  # stream-json captures the full tool-call transcript: every Read, Edit, Bash
  # the fix model runs, plus the final result envelope. Saved next to the run
  # log so we can audit what the model actually did vs. what the review asked.
  # Without this, run_fix is a black box — we see token counts but not whether
  # the model committed, pushed, or just analyzed and gave up.
  local transcript_file="${log_file%.log}-fix-iter${iteration}.jsonl"
  local rc=0
  printf '%s' "$fix_prompt" | claude -p \
    --dangerously-skip-permissions \
    --output-format stream-json \
    --verbose \
    --model "$MODEL" \
    --max-budget-usd "$MAX_BUDGET" \
    > "$transcript_file" 2>>"$log_file" || rc=$?

  # Extract the result envelope (last `.type == "result"` line). This holds
  # the cost/usage and any error subtype, regardless of success vs. failure.
  local result_line=""
  if [[ -s "$transcript_file" ]]; then
    result_line=$(jq -c 'select(.type == "result")' "$transcript_file" 2>/dev/null | tail -1)
  fi

  # Track usage even on failure so partial spend (e.g. budget-cap hit) is
  # reflected in the per-PR totals and metrics.jsonl.
  if [[ -n "$result_line" ]]; then
    track_usage "$result_line" "fix" "$log_file" "$iteration"
  fi

  if [[ $rc -ne 0 ]]; then
    local subtype="" cost=""
    if [[ -n "$result_line" ]]; then
      subtype=$(echo "$result_line" | jq -r '.subtype // empty' 2>/dev/null)
      cost=$(echo "$result_line" | jq -r '.total_cost_usd // empty' 2>/dev/null)
    fi
    if [[ "$subtype" == "error_max_budget_usd" ]]; then
      log "$log_file" "ERROR: claude fix hit --max-budget-usd cap of \$${MAX_BUDGET} (spent \$${cost}). Transcript: ${transcript_file}"
    else
      log "$log_file" "ERROR: claude fix invocation failed (exit ${rc}, subtype='${subtype:-none}'). Transcript: ${transcript_file}"
    fi
    return 1
  fi

  # Summarize what the model actually invoked. Counts tool uses by name so we
  # can see e.g. `Read=12 Edit=3 Bash=2` — useful for spotting "the model read
  # files but never edited" or "edited but never ran git".
  local tool_summary
  tool_summary=$(jq -r '
    select(.type == "assistant")
    | .message.content[]?
    | select(.type == "tool_use")
    | .name
  ' "$transcript_file" 2>/dev/null | sort | uniq -c | awk '{printf "%s=%s ", $2, $1}')
  if [[ -n "${tool_summary// }" ]]; then
    log "$log_file" "  fix tool calls: ${tool_summary}"
  else
    log "$log_file" "  fix tool calls: (none — model produced text only)"
  fi

  # Surface git-related Bash invocations so we can tell whether the model even
  # tried to commit/push. This is the smoking gun for "fix ran but HEAD didn't
  # move" — either the model never ran git, or it ran git and the push failed.
  local git_cmds
  git_cmds=$(jq -r '
    select(.type == "assistant")
    | .message.content[]?
    | select(.type == "tool_use" and .name == "Bash")
    | .input.command // empty
    | select(test("(^|[^a-zA-Z])git "))
  ' "$transcript_file" 2>/dev/null)
  if [[ -n "$git_cmds" ]]; then
    log "$log_file" "  fix git activity:"
    while IFS= read -r line; do
      [[ -n "$line" ]] && log "$log_file" "    \$ ${line}"
    done <<<"$git_cmds"
  else
    log "$log_file" "  fix git activity: NO git commands detected (model did not attempt to commit or push)"
  fi
}

# ---------------------------------------------------------------------------
# Core loop for a single PR
# ---------------------------------------------------------------------------
single_pr_loop() {
  local pr_input="$1"
  parse_pr_url "$pr_input"

  local log_file="${LOG_DIR}/${OWNER_REPO//\//_}-pr${PR_NUMBER}-$(date +%Y%m%d-%H%M%S).log"
  mkdir -p "$(dirname "$log_file")"

  # Reset usage counters for this PR
  TOTAL_INPUT_TOKENS=0
  TOTAL_OUTPUT_TOKENS=0
  TOTAL_CACHE_READ_TOKENS=0
  TOTAL_CACHE_CREATION_TOKENS=0
  TOTAL_COST_USD="0"
  ITERATION_USAGE=()
  DIFF_FILTER_SKIPPED_FILES=0
  DIFF_FILTER_SKIPPED_BYTES=0
  DIFF_RAW_BYTES=0
  DIFF_FILTERED_BYTES=0

  log "$log_file" "Starting review loop for ${OWNER_REPO}#${PR_NUMBER}"
  log "$log_file" "Config: max_iterations=${MAX_ITERATIONS} model=${MODEL} effort=${EFFORT} budget=${MAX_BUDGET} no_fix=${NO_FIX}"

  if [[ "$DRY_RUN" == "true" ]]; then
    log "$log_file" "[DRY RUN] Would clone ${OWNER_REPO}, checkout PR #${PR_NUMBER}"
    log "$log_file" "[DRY RUN] Would run up to ${MAX_ITERATIONS} review-fix iterations"
    log "$log_file" "[DRY RUN] Review: claude -p --from-pr https://github.com/${OWNER_REPO}/pull/${PR_NUMBER} --model ${MODEL}"
    log "$log_file" "[DRY RUN] Fix: claude -p --dangerously-skip-permissions --model ${MODEL}"
    return
  fi

  # Set up worktree
  local worktree_dir
  worktree_dir=$(setup_worktree "$OWNER_REPO" "$PR_NUMBER")
  trap 'cleanup_worktree "'"$worktree_dir"'"' EXIT

  local iteration=0
  local verdict="changes_requested"
  # Findings hash from the previous iteration. If the next review returns the
  # same set of findings, the fix step made no useful change — bail out
  # rather than burn another full review-fix cycle.
  local prev_findings_hash=""

  while [[ "$iteration" -lt "$MAX_ITERATIONS" && "$verdict" != "approve" ]]; do
    iteration=$((iteration + 1))
    log "$log_file" "=== Iteration ${iteration}/${MAX_ITERATIONS} ==="

    # Step 1: Review
    log "$log_file" "Running review..."
    local claude_output review_json review_rc
    claude_output=$(run_review "$OWNER_REPO" "$PR_NUMBER" "$iteration" "$log_file" "$worktree_dir") && review_rc=0 || review_rc=$?
    if [[ $review_rc -ne 0 ]]; then
      log "$log_file" "Review step failed — aborting loop. Check stderr in log above."
      # Re-read the log tail to detect the budget-exhaustion path set in run_review.
      if grep -q "hit --max-budget-usd cap" "$log_file"; then
        verdict="budget_exhausted"
      else
        verdict="invocation_failed"
      fi
      break
    fi
    track_usage "$claude_output" "review" "$log_file" "$iteration"
    review_json=$(parse_review "$claude_output")

    if [[ -z "$review_json" ]] || ! echo "$review_json" | jq -e '.verdict' >/dev/null 2>&1; then
      log "$log_file" "ERROR: Failed to parse review output"
      echo "--- Raw Claude output ---" >> "$log_file"
      echo "$claude_output" >> "$log_file"
      echo "--- End raw output ---" >> "$log_file"
      verdict="parse_failed"
      break
    fi

    verdict=$(echo "$review_json" | jq -r '.verdict')
    local finding_count
    finding_count=$(echo "$review_json" | jq '[.findings[] | select(.severity != "suggestion")] | length')
    log "$log_file" "Verdict: ${verdict} (${finding_count} actionable findings)"

    # Convergence guard: hash the findings (severity/file/line/message). If
    # this iteration's findings are identical to the previous iteration's,
    # the fix step is not making the issues go away — stop the loop.
    local findings_hash
    findings_hash=$(echo "$review_json" | jq -c '[.findings[] | {severity, file, line, message}] | sort' 2>/dev/null | shasum | awk '{print $1}')
    if [[ -n "$prev_findings_hash" && "$findings_hash" == "$prev_findings_hash" ]]; then
      log "$log_file" "Findings unchanged from previous iteration (hash ${findings_hash:0:12}). Fix step is not converging — stopping."
      verdict="no_progress"
      break
    fi
    prev_findings_hash="$findings_hash"

    # Step 2: Post review
    post_review "$PR_NUMBER" "$OWNER_REPO" "$review_json" "$log_file"

    # Step 3: Fix (if needed and allowed)
    if [[ "$verdict" != "approve" ]]; then
      if [[ "$NO_FIX" == "true" ]]; then
        log "$log_file" "Review-only mode (--no-fix). Stopping after review."
        break
      fi

      # Snapshot HEAD so we can detect a no-op fix (model ran but never committed).
      local pre_fix_head
      pre_fix_head=$(git -C "$worktree_dir" rev-parse HEAD 2>/dev/null || echo "")

      log "$log_file" "Running fix pass..."
      if ! run_fix "$worktree_dir" "$review_json" "$log_file" "$iteration"; then
        log "$log_file" "Fix step failed — aborting loop. Check stderr in log above."
        verdict="fix_failed"
        break
      fi

      # Also re-fetch the PR ref so review sees the new commits
      local bare_repo
      bare_repo="$(dirname "$worktree_dir")/bare.git"
      sleep 5  # Let GitHub index the push

      # Pull latest into worktree
      cd "$worktree_dir"
      git pull --rebase origin "$(git branch --show-current)" 2>>"$log_file" || true

      # Verify the fix step actually produced a commit. If HEAD didn't move,
      # the model didn't commit (or commit failed) and another review iteration
      # will return the same findings. Bail out instead of burning more budget.
      local post_fix_head
      post_fix_head=$(git -C "$worktree_dir" rev-parse HEAD 2>/dev/null || echo "")
      if [[ -n "$pre_fix_head" && "$pre_fix_head" == "$post_fix_head" ]]; then
        log "$log_file" "Fix step did not commit any changes (HEAD still at ${pre_fix_head:0:7}). Stopping — fix is a no-op."
        verdict="no_commit"
        break
      fi
    fi
  done

  # Usage summary
  log_usage_summary "$log_file" "$iteration"
  write_metrics "${OWNER_REPO}#${PR_NUMBER}" "$verdict" "$iteration" "$log_file"

  # Final status + notification
  if [[ "$verdict" == "approve" ]]; then
    log "$log_file" "PR #${PR_NUMBER} APPROVED after ${iteration} iteration(s)"
    gh pr edit "$PR_NUMBER" --repo "$OWNER_REPO" --add-label "lauren-approved-via-claude" 2>>"$log_file" || true
    log "$log_file" "Added 'lauren-approved-via-claude' label"
    notify "PR Approved" "${OWNER_REPO}#${PR_NUMBER} passed review (${iteration} iterations)"
  elif [[ "$verdict" == "budget_exhausted" ]]; then
    log "$log_file" "PR #${PR_NUMBER} stopped: hit --max-budget-usd cap of \$${MAX_BUDGET}. Rerun with a higher --max-budget-usd."
    notify "PR Loop Budget" "${OWNER_REPO}#${PR_NUMBER} — budget cap hit, rerun with higher --max-budget-usd"
  elif [[ "$verdict" == "invocation_failed" ]]; then
    log "$log_file" "PR #${PR_NUMBER} stopped: claude review invocation failed (transport or unknown error — check log for stderr)"
    notify "PR Loop Error" "${OWNER_REPO}#${PR_NUMBER} — claude invocation failed, check logs"
  elif [[ "$verdict" == "parse_failed" ]]; then
    log "$log_file" "PR #${PR_NUMBER} stopped: could not parse review JSON from claude output"
    notify "PR Loop Error" "${OWNER_REPO}#${PR_NUMBER} — review parse error, check logs"
  elif [[ "$verdict" == "fix_failed" ]]; then
    log "$log_file" "PR #${PR_NUMBER} stopped: claude fix invocation failed (check log for stderr)"
    notify "PR Loop Error" "${OWNER_REPO}#${PR_NUMBER} — fix step failed, check logs"
  elif [[ "$verdict" == "no_commit" ]]; then
    log "$log_file" "PR #${PR_NUMBER} stopped: fix step ran but committed nothing (likely the model declined to make changes, or a push failed silently). Findings will not be fixed by another iteration."
    notify "PR Loop Stalled" "${OWNER_REPO}#${PR_NUMBER} — fix made no commits, manual intervention needed"
  elif [[ "$verdict" == "no_progress" ]]; then
    log "$log_file" "PR #${PR_NUMBER} stopped: review findings unchanged after a fix iteration. Loop is not converging — review the findings manually."
    notify "PR Loop Stalled" "${OWNER_REPO}#${PR_NUMBER} — findings unchanged, manual intervention needed"
  elif [[ "$iteration" -ge "$MAX_ITERATIONS" ]]; then
    log "$log_file" "PR #${PR_NUMBER} hit max iterations (${MAX_ITERATIONS}) without approval"
    notify "PR Loop Exhausted" "${OWNER_REPO}#${PR_NUMBER} — ${MAX_ITERATIONS} iterations, still has issues"
  fi

  log "$log_file" "Log: ${log_file}"
  cleanup_worktree "$worktree_dir"
  trap - EXIT
}

# ---------------------------------------------------------------------------
# Batch mode — process multiple PRs in parallel
# ---------------------------------------------------------------------------
batch_run() {
  local label="$1" repo="$2"

  local prs
  prs=$(gh pr list --repo "$repo" --label "$label" --state open --json number,url,title --limit 50)
  local count
  count=$(echo "$prs" | jq 'length')

  if [[ "$count" -eq 0 ]]; then
    echo "No open PRs found with label '${label}' in ${repo}"
    exit 0
  fi

  echo "Found ${count} PR(s) with label '${label}' in ${repo}:"
  echo "$prs" | jq -r '.[] | "  #\(.number) — \(.title)"'
  echo ""

  local pids=()
  local pr_numbers=()

  while IFS= read -r pr_line; do
    local url number title
    url=$(echo "$pr_line" | jq -r '.url')
    number=$(echo "$pr_line" | jq -r '.number')
    title=$(echo "$pr_line" | jq -r '.title')

    echo "Starting background loop for PR #${number}: ${title}"
    single_pr_loop "$url" &
    pids+=($!)
    pr_numbers+=("$number")
  done < <(echo "$prs" | jq -c '.[]')

  echo ""
  echo "All ${count} PR(s) running in background. PIDs: ${pids[*]}"
  echo "Logs: ${LOG_DIR}/"
  echo ""

  # Wait for all
  local failed=0
  for i in "${!pids[@]}"; do
    if ! wait "${pids[$i]}"; then
      echo "PR #${pr_numbers[$i]} loop failed (exit code $?)"
      failed=$((failed + 1))
    else
      echo "PR #${pr_numbers[$i]} loop completed"
    fi
  done

  echo ""
  echo "Batch complete: $((count - failed))/${count} succeeded"
  notify "Batch Review Complete" "${repo}: ${count} PRs processed (label: ${label}), ${failed} failed"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
  parse_args "$@"

  # Preflight checks
  for cmd in claude gh git jq; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      echo "Error: '${cmd}' not found in PATH" >&2
      exit 1
    fi
  done

  mkdir -p "$LOG_DIR" "$WORKTREE_BASE"

  if [[ -n "$BATCH_LABEL" ]]; then
    batch_run "$BATCH_LABEL" "$BATCH_REPO"
  else
    single_pr_loop "$PR_INPUT"
  fi
}

main "$@"
